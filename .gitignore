# Rust
/target/
/**/target/
*.iml
.idea/
.vscode/

# Tauri
**/src-tauri/target/
**/src-tauri/gen/
# Sidecar binaries staged into the Tauri bundle by scripts/ci.sh — built
# at release time and copied here so tauri-bundler picks them up via the
# `externalBin` entry in tauri.conf.json. Never committed.
app/src-tauri/binaries/

# Frontend
node_modules/
dist/
dist-ssr/
.svelte-kit/
*.local

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Editor
*.swp
*.swo

# Claude Code local session state / worktrees — never committed
.claude/

# plaintext-ide runtime
.plaintext-ide/cache/

# ProjectMind per-repo runtime state written into a target repo when it is
# opened: the Cockpit 2.7 session log (.projectmind/state/sessions.jsonl) and
# the Cockpit 2.5 semantic tour cache (.projectmind/cache/). Never committed —
# they are machine-local, regenerated on the next open_repo.
.projectmind/state/
.projectmind/cache/

# Local release/updater staging (left behind by local `./build dist` runs;
# CI produces and uploads these as release assets instead)
/artifacts/
/updater-stage/
/latest.json
/*.tar.gz
/*.tar.gz.sha256
